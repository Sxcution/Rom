<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen android:title="@string/button_pref_title" android:key="button_settings"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:settings="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory android:title="@string/navigation_bar_title" android:key="navbar_key">
        <SwitchPreference android:title="@string/disable_navkeys_title" android:key="disable_nav_keys" android:summary="@string/disable_navkeys_summary" android:defaultValue="false" />
        <Preference android:title="@string/system_navigation_title" android:key="navbar_gestures" android:fragment="com.android.settings.gestures.SystemNavigationGestureSettings" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/navigation_bar_compact_layout_title" android:key="navigation_bar_compact_layout" android:summary="@string/navigation_bar_compact_layout_summary" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/navigation_bar_arrow_keys_title" android:key="navigation_bar_menu_arrow_keys" android:summary="@string/navigation_bar_arrow_keys_summary" android:defaultValue="false" />
        <com.android.settings.custom.preference.SecureSettingSwitchPreference android:title="@string/nav_bar_layout_inverse_title" android:key="sysui_nav_bar_inverse" android:summary="@string/nav_bar_layout_inverse_summary" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/navigation_bar_edge_long_swipe_title" android:key="navigation_bar_edge_long_swipe" android:dialogTitle="@string/navigation_bar_edge_long_swipe_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_power_key_title" android:key="power_key">
        <Preference android:title="@string/power_menu_setting_name" android:key="gesture_power_menu_summary" android:fragment="com.android.settings.gestures.PowerMenuSettings" />
        <SwitchPreference android:persistent="false" android:title="@string/power_end_call_title" android:key="power_end_call" android:summary="@string/power_end_call_summary" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/torch_long_press_power_gesture_title" android:key="torch_long_press_power_gesture" android:summary="@string/torch_long_press_power_gesture_desc" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/torch_long_press_power_timeout_entries" android:title="@string/torch_long_press_power_timeout_title" android:key="torch_long_press_power_timeout" android:summary="%s" android:dependency="torch_long_press_power_gesture" android:defaultValue="0" android:dialogTitle="@string/torch_long_press_power_timeout_title" android:entryValues="@array/torch_long_press_power_timeout_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_volume_keys_title" android:key="volume_keys">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="volume_wake_screen" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/volume_answer_call_title" android:key="volume_answer_call" android:summary="@string/volume_answer_call_summary" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/volbtn_music_controls_title" android:key="volbtn_music_controls" android:summary="@string/volbtn_music_controls_summary" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/volbtn_cursor_control_entries" android:title="@string/volbtn_cursor_control_title" android:key="volume_key_cursor_control" android:dialogTitle="@string/volbtn_cursor_control_title" android:entryValues="@array/volbtn_cursor_control_values" />
        <SwitchPreference android:title="@string/swap_volume_buttons_title" android:key="swap_volume_buttons" android:summary="@string/swap_volume_buttons_summary" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/click_partial_screenshot_title" android:key="click_partial_screenshot" android:summary="@string/click_partial_screenshot_summary" android:defaultValue="false" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/swap_capacitive_keys_title" android:key="swap_capacitive_keys_cat">
        <com.android.settings.custom.preference.SecureSettingSwitchPreference android:title="@string/swap_capacitive_keys_title" android:key="swap_capacitive_keys" android:summary="@string/swap_capacitive_keys_summary" android:defaultValue="false" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/button_backlight_title" android:key="button_backlight_cat">
        <com.android.settings.custom.buttons.preference.ButtonBacklightBrightness android:persistent="false" android:title="@string/button_backlight_title" android:key="button_backlight" android:dialogTitle="@string/button_backlight_title" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_home_key_title" android:key="home_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="home_wake_screen" android:defaultValue="true" />
        <SwitchPreference android:persistent="false" android:title="@string/home_answer_call_title" android:key="home_answer_call" android:summary="@string/home_answer_call_summary" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_long_press_title" android:key="hardware_keys_home_long_press" android:dialogTitle="@string/hardware_keys_long_press_title" android:entryValues="@array/hardware_keys_action_values" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_double_tap_title" android:key="hardware_keys_home_double_tap" android:dialogTitle="@string/hardware_keys_double_tap_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_back_key_title" android:key="back_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="back_wake_screen" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_long_press_title" android:key="hardware_keys_back_long_press" android:dialogTitle="@string/hardware_keys_long_press_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_menu_key_title" android:key="menu_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="menu_wake_screen" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_short_press_title" android:key="hardware_keys_menu_press" android:dialogTitle="@string/hardware_keys_short_press_title" android:entryValues="@array/hardware_keys_action_values" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_long_press_title" android:key="hardware_keys_menu_long_press" android:dialogTitle="@string/hardware_keys_long_press_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_assist_key_title" android:key="assist_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="assist_wake_screen" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_short_press_title" android:key="hardware_keys_assist_press" android:dialogTitle="@string/hardware_keys_short_press_title" android:entryValues="@array/hardware_keys_action_values" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_long_press_title" android:key="hardware_keys_assist_long_press" android:dialogTitle="@string/hardware_keys_long_press_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_appswitch_key_title" android:key="app_switch_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="app_switch_wake_screen" android:defaultValue="false" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_short_press_title" android:key="hardware_keys_app_switch_press" android:dialogTitle="@string/hardware_keys_short_press_title" android:entryValues="@array/hardware_keys_action_values" />
        <ListPreference android:persistent="false" android:entries="@array/hardware_keys_action_entries" android:title="@string/hardware_keys_long_press_title" android:key="hardware_keys_app_switch_long_press" android:dialogTitle="@string/hardware_keys_long_press_title" android:entryValues="@array/hardware_keys_action_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/hardware_keys_camera_key_title" android:key="camera_key">
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/button_wake_title" android:key="camera_wake_screen" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/camera_sleep_on_release_title" android:key="camera_sleep_on_release" android:summary="@string/camera_sleep_on_release_summary" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/camera_launch_title" android:key="camera_launch" android:summary="@string/camera_launch_summary" android:defaultValue="false" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/others_settings_title" android:key="others_settings_category">
        <com.android.settings.custom.preference.RemotePreference android:title="@string/additional_buttons_title" android:key="additional_buttons" settings:requiresAction="org.lineageos.settings.device.ADDITIONAL_BUTTONS_SETTINGS">
            <intent android:action="org.lineageos.settings.device.ADDITIONAL_BUTTONS_SETTINGS" />
        </com.android.settings.custom.preference.RemotePreference>
    </PreferenceCategory>
</PreferenceScreen>
