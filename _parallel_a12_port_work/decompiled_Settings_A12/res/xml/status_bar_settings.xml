<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen android:title="@string/status_bar_title" android:key="status_bar_settings"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <Preference android:title="@string/network_traffic_settings_title" android:key="network_traffic_settings" android:summary="@string/network_traffic_settings_summary" android:fragment="com.android.settings.custom.statusbar.NetworkTrafficSettings" />
    <PreferenceCategory android:title="@string/status_bar_icons_title">
        <Preference android:title="@string/status_bar_system_icons_title" android:key="status_bar_icons" android:summary="@string/status_bar_system_icons_summary">
            <intent android:action="com.android.settings.action.STATUS_BAR_TUNER" />
        </Preference>
    </PreferenceCategory>
    <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/status_bar_double_tap_to_sleep_title" android:key="double_tap_sleep_gesture" android:summary="@string/status_bar_double_tap_to_sleep_summary" android:defaultValue="false" />
    <PreferenceCategory android:title="@string/status_bar_clock_title" android:key="status_bar_clock_key">
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/status_bar_clock_position_entries" android:title="@string/status_bar_clock_position_title" android:key="status_bar_clock" android:summary="%s" android:defaultValue="2" android:dialogTitle="@string/status_bar_clock_position_title" android:entryValues="@array/status_bar_clock_position_values" />
        <com.android.settings.custom.preference.SecureSettingSwitchPreference android:title="@string/status_bar_clock_show_seconds_title" android:key="clock_seconds" android:summary="@string/status_bar_clock_show_seconds_summary" android:defaultValue="false" />
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/status_bar_am_pm_entries" android:title="@string/status_bar_am_pm_title" android:key="status_bar_am_pm" android:summary="%s" android:defaultValue="2" android:dialogTitle="@string/status_bar_am_pm_title" android:entryValues="@array/status_bar_am_pm_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/status_bar_battery_title" android:key="status_bar_battery_key">
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/status_bar_battery_style_entries" android:title="@string/status_bar_battery_style_title" android:key="status_bar_battery_style" android:summary="%s" android:defaultValue="0" android:dialogTitle="@string/status_bar_battery_style_title" android:entryValues="@array/status_bar_battery_style_values" />
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/status_bar_battery_percentage_entries" android:title="@string/status_bar_battery_percentage_title" android:key="status_bar_show_battery_percent" android:summary="%s" android:defaultValue="0" android:dialogTitle="@string/status_bar_battery_percentage_title" android:entryValues="@array/status_bar_battery_percentage_values" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/status_bar_brightness_category" android:key="status_bar_brightness_category">
        <com.android.settings.custom.preference.SecureSettingSwitchPreference android:title="@string/status_bar_brightness_slider_title" android:key="qs_show_brightness_slider" android:summary="@string/status_bar_brightness_slider_summary" android:defaultValue="true" />
        <com.android.settings.custom.preference.SecureSettingSwitchPreference android:title="@string/status_bar_brightness_slider_auto_title" android:key="qs_show_auto_brightness" android:summary="@string/status_bar_brightness_slider_auto_summary" android:dependency="qs_show_brightness_slider" android:defaultValue="true" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/status_bar_toggle_brightness" android:key="status_bar_brightness_control" android:summary="@string/status_bar_toggle_brightness_summary" android:defaultValue="false" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/qs_title">
        <com.android.settings.custom.preference.SystemSettingListPreference android:entries="@array/status_bar_quick_qs_pulldown_entries" android:title="@string/status_bar_quick_qs_pulldown_title" android:key="qs_quick_pulldown" android:defaultValue="0" android:entryValues="@array/status_bar_quick_qs_pulldown_values" />
    </PreferenceCategory>
</PreferenceScreen>
