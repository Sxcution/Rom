<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen android:title="@android:string/live_display_title" android:key="livedisplay"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <com.android.settingslib.widget.LayoutPreference android:layout="@layout/color_mode_preview" android:selectable="false" android:key="color_mode_preview" />
    <ListPreference android:persistent="false" android:title="@string/live_display_color_profile_title" android:key="live_display_color_profile" />
    <ListPreference android:persistent="false" android:title="@string/live_display_mode" android:key="live_display" />
    <com.android.settings.livedisplay.DisplayTemperature android:persistent="false" android:title="@string/live_display_color_temperature_title" android:key="live_display_color_temperature" android:dialogTitle="@android:string/live_display_title" />
    <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/live_display_outdoor_mode_title" android:key="display_auto_outdoor_mode" android:summary="@string/live_display_outdoor_mode_summary" android:defaultValue="@android:bool/config_defaultAutoOutdoorMode" />
    <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/live_display_anti_flicker_title" android:key="display_anti_flicker" android:summary="@string/live_display_anti_flicker_summary" android:defaultValue="false" />
    <com.android.settings.custom.preference.SystemSettingSwitchPreference android:persistent="false" android:title="@string/live_display_reading_mode_title" android:key="display_reading_mode" android:summary="@string/live_display_reading_mode_summary" android:defaultValue="false" />
    <PreferenceCategory android:title="@string/advanced_settings" android:key="advanced">
        <com.android.settings.livedisplay.DisplayColor android:persistent="false" android:title="@string/color_calibration_title" android:key="color_calibration" android:summary="@string/color_calibration_summary" android:dialogTitle="@string/color_calibration_title" />
        <com.android.settings.livedisplay.PictureAdjustment android:persistent="false" android:title="@string/picture_adjustment_title" android:key="picture_adjustment" android:summary="@string/picture_adjustment_summary" android:dialogTitle="@string/picture_adjustment_title" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/live_display_low_power_title" android:key="display_low_power" android:summary="@string/live_display_low_power_summary" android:defaultValue="@android:bool/config_defaultCABC" />
        <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/live_display_enhance_color_title" android:key="display_color_enhance" android:summary="@string/live_display_enhance_color_summary" android:defaultValue="@android:bool/config_defaultColorEnhancement" />
    </PreferenceCategory>
</PreferenceScreen>
