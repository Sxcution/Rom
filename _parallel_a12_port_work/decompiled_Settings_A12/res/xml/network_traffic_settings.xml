<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen android:title="@string/network_traffic_settings_title"
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:settings="http://schemas.android.com/apk/res/com.android.settings">
    <DropDownPreference android:persistent="false" android:entries="@array/network_traffic_mode_entries" android:title="@string/network_traffic_mode_title" android:key="network_traffic_location" android:summary="%s" android:entryValues="@array/network_traffic_mode_values" />
    <com.android.settings.custom.preference.SystemSettingSwitchPreference android:title="@string/network_traffic_autohide" android:key="network_traffic_autohide" android:summary="@string/network_traffic_autohide_summary" android:defaultValue="false" />
    <DropDownPreference android:persistent="false" android:entries="@array/network_traffic_units_entries" android:title="@string/network_traffic_units_title" android:key="network_traffic_unit_type" android:summary="%s" android:entryValues="@array/network_traffic_units_values" />
</PreferenceScreen>
